# Base URL of the station's FastAPI server, exposed to the internet via a
# Cloudflare Tunnel (see station/TUNNEL.md). The browser calls this directly
# for printer status + camera snapshots.
STATION_API_URL=https://makerlab-status.YOUR_TUNNEL.cfargotunnel.com

# Vercel Blob read/write token (create a Blob store in the Vercel dashboard).
# Used by /api/upload to store student submissions under "incoming/".
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_REPLACE_ME

# Base URL of the station's FastAPI server, exposed to the internet via a
# Cloudflare Tunnel (see station/TUNNEL.md). The browser calls this directly
# for printer status + camera snapshots, and /api/upload calls it after each
# submission to tell the laptop to come download the blob (webhook-driven, no
# polling).
STATION_API_URL=https://makerlab-status.YOUR_TUNNEL.cfargotunnel.com

# Shared secret sent in the x-station-key header when notifying the laptop's
# /api/blob-webhook endpoint. Must match web.webhook_secret in the laptop's
# config.json. Generate with: openssl rand -hex 32
STATION_WEBHOOK_SECRET=replace_with_long_random_secret

# Vercel Blob read/write token (create a Blob store in the Vercel dashboard).
# Used by /api/upload to store student submissions under "incoming/".
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_REPLACE_ME
